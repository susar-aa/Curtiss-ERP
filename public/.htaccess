<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /Curtiss-ERP/

    # 1. Skip if the file or directory actually exists
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 2. Redirect everything else to public/index.php
    # This captures the path after public/ and passes it to the router
    RewriteRule ^public/(.*)$ public/index.php?url=$1 [QSA,L]

    # 3. Handle default case if accessed without public/
    RewriteRule ^(.*)$ public/index.php?url=$1 [QSA,L]
</IfModule>