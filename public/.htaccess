<IfModule mod_rewrite.c>
    RewriteEngine On

    # 1. Skip if the file or directory actually exists
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 2. Redirect everything else relative to index.php
    RewriteRule ^(.*)$ index.php?url=$1 [QSA,L]
</IfModule>