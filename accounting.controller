const pool = require('../../config/db');

// ==========================================
// CHART OF ACCOUNTS
// ==========================================

// @desc    Get all accounts (Chart of Accounts)
// @route   GET /api/accounting/accounts
// @access  Private (Admin, Accountant, Manager)
exports.getAccounts = async (req, res, next) => {
    try {
        const [rows] = await pool.query('SELECT * FROM Accounts ORDER BY type, name');
        res.status(200).json({ status: 'success', results: rows.length, data: { accounts: rows } });
    } catch (error) {
        next(error);
    }
};

// @desc    Create new account
// @route   POST /api/accounting/accounts
// @access  Private (Admin, Accountant)
exports.createAccount = async (req, res, next) => {
    try {
        const { name, type } = req.body;
        const validTypes = ['Asset', 'Liability', 'Equity', 'Revenue', 'Expense'];

        if (!name || !validTypes.includes(type)) {
            return res.status(400).json({ status: 'error', message: 'Valid account name and type are required' });
        }

        const [result] = await pool.query('INSERT INTO Accounts (name, type) VALUES (?, ?)', [name, type]);
        res.status(201).json({ status: 'success', data: { account: { id: result.insertId, name, type } } });
    } catch (error) {
        next(error);
    }
};

// ==========================================
// JOURNAL ENTRIES (TRANSACTIONS)
// ==========================================

// @desc    Create a double-entry journal transaction
// @route   POST /api/accounting/transactions
// @access  Private (Admin, Accountant)
exports.createJournalEntry = async (req, res, next) => {
    // Expects an array of entries: [{ account_id, debit, credit, description, transaction_date }]
    const connection = await pool.getConnection();
    try {
        const { entries } = req.body;

        if (!entries || entries.length < 2) {
            return res.status(400).json({ status: 'error', message: 'At least two entries required for double-entry bookkeeping' });
        }

        // Validate debits = credits
        let totalDebit = 0;
        let totalCredit = 0;
        entries.forEach(entry => {
            totalDebit += parseFloat(entry.debit || 0);
            totalCredit += parseFloat(entry.credit || 0);
        });

        if (totalDebit.toFixed(2) !== totalCredit.toFixed(2)) {
            return res.status(400).json({ status: 'error', message: `Debits (${totalDebit}) must equal Credits (${totalCredit})` });
        }

        // Start MySQL Transaction to ensure all or nothing is saved
        await connection.beginTransaction();

        for (const entry of entries) {
            await connection.query(
                'INSERT INTO Transactions (account_id, debit, credit, description, transaction_date) VALUES (?, ?, ?, ?, ?)',
                [entry.account_id, entry.debit || 0, entry.credit || 0, entry.description, entry.transaction_date || new Date()]
            );
        }

        await connection.commit();
        res.status(201).json({ status: 'success', message: 'Journal entry created successfully' });
    } catch (error) {
        await connection.rollback();
        next(error);
    } finally {
        connection.release();
    }
};

// @desc    Get general ledger (all transactions)
// @route   GET /api/accounting/transactions
// @access  Private (Admin, Accountant, Manager)
exports.getTransactions = async (req, res, next) => {
    try {
        const query = `
            SELECT t.id, t.debit, t.credit, t.description, t.transaction_date, a.name as account_name, a.type as account_type
            FROM Transactions t
            JOIN Accounts a ON t.account_id = a.id
            ORDER BY t.transaction_date DESC, t.id DESC
        `;
        const [rows] = await pool.query(query);
        res.status(200).json({ status: 'success', results: rows.length, data: { transactions: rows } });
    } catch (error) {
        next(error);
    }
};

// ==========================================
// FINANCIAL REPORTS
// ==========================================

// @desc    Get Profit and Loss Statement Data
// @route   GET /api/accounting/reports/pl
// @access  Private (Admin, Accountant, Manager)
exports.getProfitAndLoss = async (req, res, next) => {
    try {
        // P&L looks at Revenue and Expense accounts
        const query = `
            SELECT a.name, a.type, SUM(t.debit) as total_debit, SUM(t.credit) as total_credit
            FROM Accounts a
            LEFT JOIN Transactions t ON a.id = t.account_id
            WHERE a.type IN ('Revenue', 'Expense')
            GROUP BY a.id, a.name, a.type
        `;
        const [rows] = await pool.query(query);
        res.status(200).json({ status: 'success', data: { report: rows } });
    } catch (error) {
        next(error);
    }
};